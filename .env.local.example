# PostHog — get these from https://posthog.com after creating a project
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# MercadoPago
MP_ACCESS_TOKEN=              # Production access token from MP dashboard
MP_WEBHOOK_SECRET=            # Webhook signature secret (optional in dev)

# Redis (auto-set when Redis store is connected in Vercel)
REDIS_URL=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=brote@harisolaas.com

# Admin secret for /api/brote/attendees export
BROTE_ADMIN_SECRET=

# Un Árbol community discount code (shared, reusable)
BROTE_UNARBOL_CODE=MESUMOALPLANTEL

# Meta Pixel + Conversions API
NEXT_PUBLIC_META_PIXEL_ID=      # Meta Pixel ID (exposed to client)
META_PIXEL_ID=                  # Same value, used server-side by CAPI
META_CAPI_TOKEN=                # Conversions API token from Meta Events Manager

# Base URL
NEXT_PUBLIC_BASE_URL=https://www.harisolaas.com
