# PostHog — get these from https://posthog.com after creating a project
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# MercadoPago
MP_ACCESS_TOKEN=              # Production access token from MP dashboard
MP_WEBHOOK_SECRET=            # Webhook signature secret (optional in dev)

# Redis (auto-set when Redis store is connected in Vercel)
REDIS_URL=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=brote@harisolaas.com

# Base URL
NEXT_PUBLIC_BASE_URL=https://harisolaas.com
